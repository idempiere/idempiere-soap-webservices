<?xml version="1.0" encoding="UTF-8"?>
<project
    xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <groupId>org.idempiere.soap</groupId>
    <artifactId>org.idempiere.soap.parent</artifactId>
    <version>${revision}</version>
    <packaging>pom</packaging>
    <name>Maven parent project for iDempiere SOAP Webservices</name>

    <properties>
        <revision>14.0.0-SNAPSHOT</revision>
        <tycho.version>4.0.8</tycho.version>
        <tycho.extras.version>${tycho.version}</tycho.extras.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <idempiere.target>org.idempiere.p2.targetplatform</idempiere.target>

        <!-- Default: idempiere core repo is a sibling folder -->
        <idempiere.core.repository.url>file:///${basedir}/../../idempiere/org.idempiere.p2/target/repository</idempiere.core.repository.url>

        <!-- Generated by org.idempiere.webservice.client -->
        <soap.client.repository.url>file:///${basedir}/../org.idempiere.webservice.client/target/repository</soap.client.repository.url>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.eclipse.tycho</groupId>
                <artifactId>tycho-maven-plugin</artifactId>
                <version>${tycho.version}</version>
                <extensions>true</extensions>
            </plugin>

            <plugin>
                <groupId>org.eclipse.tycho</groupId>
                <artifactId>tycho-source-plugin</artifactId>
                <version>${tycho.version}</version>
                <executions>
                    <execution>
                        <id>plugin-source</id>
                        <goals>
                            <goal>plugin-source</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>feature-source</id>
                        <goals>
                            <goal>feature-source</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>build.idempiere.soap</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>

            <repositories>
                <repository>
                    <id>idempiere-core</id>
                    <url>${idempiere.core.repository.url}</url>
                    <layout>p2</layout>
                </repository>

                <repository>
                    <id>soap-client-p2</id>
                    <url>${soap.client.repository.url}</url>
                    <layout>p2</layout>
                </repository>
            </repositories>

            <build>
                <plugins>
                    <plugin>
                        <groupId>org.eclipse.tycho</groupId>
                        <artifactId>target-platform-configuration</artifactId>
                        <version>${tycho.version}</version>
                        <configuration>
                            <environments>
                                <environment>
                                    <os>linux</os>
                                    <ws>gtk</ws>
                                    <arch>x86_64</arch>
                                </environment>
                                <environment>
                                    <os>win32</os>
                                    <ws>win32</ws>
                                    <arch>x86_64</arch>
                                </environment>
                            </environments>
                            <executionEnvironmentDefault>JavaSE-17</executionEnvironmentDefault>
                            <executionEnvironment>JavaSE-17</executionEnvironment>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
